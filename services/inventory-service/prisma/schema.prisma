generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "multiSchema"]
  output          = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["inventory"]
}

model Product {
  id    String @id
  stock Int

  @@schema("inventory")
}

model Reservation {
  id        String   @id @default(uuid())
  orderId   String   @unique
  productId String
  quantity  Int
  status    String  
  createdAt DateTime @default(now())

  @@schema("inventory")
}