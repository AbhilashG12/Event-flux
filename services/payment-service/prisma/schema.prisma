generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters", "multiSchema"]
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  schemas  = ["payments"]
  
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String   @unique
  amount    Float
  status    String
  createdAt DateTime @default(now())
  @@schema("payments")
}