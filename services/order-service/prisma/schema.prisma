generator client {
  provider   = "prisma-client-js"
  previewFeatures = ["driverAdapters", "multiSchema"]
  output   = "../generated/prisma"

}

datasource db {
  provider = "postgresql"
  schemas  = ["orders"]
}

model Order {
  id        String   @id
  userId    String
  amount    Float
  status    String
  createdAt DateTime @default(now())
  @@schema("orders")
}